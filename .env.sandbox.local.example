# Optional machine-local sandbox overrides (gitignored).
# Default sandbox mode does NOT use a proxy — agents reach API endpoints directly.
#
# Copy only when you need custom settings:
#   cp .env.sandbox.local.example .env.sandbox.local
#
# ---------------------------------------------------------------------------
# Outbound proxy (optional)
# ---------------------------------------------------------------------------
# Enable only when sandbox containers cannot reach LLM API endpoints directly
# (OpenAI, Anthropic, etc.). Not required for normal deployments.
#
# Option A — auto-detect local Clash mixed port (requires host network):
# NIKA_SANDBOX_NETWORK=host
# NIKA_SANDBOX_AUTO_PROXY=true
#
# Option B — explicit proxy URL:
# NIKA_SANDBOX_HTTP_PROXY=http://127.0.0.1:7890
# NIKA_SANDBOX_HTTPS_PROXY=http://127.0.0.1:7890
# NIKA_SANDBOX_NO_PROXY=localhost,127.0.0.1,host.docker.internal
