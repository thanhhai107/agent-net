# Variable template — copy to .env and fill in values.
# Usage, example commands, and CLI override rules: see README.md § Configure environment variables.

# =============================================================================
# API keys (required by the LLM provider you use)
# =============================================================================

# ReAct / Mock agent with -p deepseek, or LangChain DeepSeek calls
DEEPSEEK_API_KEY=

# ReAct / Mock agent with -p openai, Codex CLI agent, or LLM judge with openai
OPENAI_API_KEY=

# ReAct / Mock agent with -p ollama
OLLAMA_API_URL=http://localhost:11434

# =============================================================================
# Observability (ReAct, Codex CLI, Claude CLI agents)
# =============================================================================

# LangSmith — https://docs.smith.langchain.com/
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=NIKA

# Langfuse — https://langfuse.com/docs
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# =============================================================================
# Agent options (nika agent run / nika benchmark run)
# Required unless the matching CLI flag is passed (-a, -p, -n, -m, -e).
# CLI flags override .env when both are set.
# =============================================================================

# Agent implementation: react, mock, codex_cli, claude_cli
NIKA_AGENT_TYPE=react

# LLM provider for react agent only: openai, ollama, deepseek, custom
NIKA_LLM_PROVIDER=openai

# Location of the custom provider, when NIKA_LLM_PROVIDER==custom
# CUSTOM_API_BASE=http://10.XXX.XXX.XXX:8010/v1

# Max ReAct steps per phase (react and mock only)
NIKA_MAX_STEPS=20

# Optional generic model override for any agent type (-m takes precedence)
# NIKA_MODEL=

# =============================================================================
# ReAct agent (-a react)
# =============================================================================

NIKA_REACT_MODEL=gpt-5-mini

# =============================================================================
# Mock agent (-a mock)
# =============================================================================

NIKA_MOCK_MODEL=mock-v1

# =============================================================================
# Codex CLI agent (-a codex_cli)
# Requires Codex CLI installed; authenticate with `codex login` or OPENAI_API_KEY.
# =============================================================================

NIKA_CODEX_MODEL=gpt-5.4-mini

# Codex model_reasoning_effort: none, minimal, low, medium, high, xhigh
# NIKA_CODEX_REASONING_EFFORT=

# =============================================================================
# Claude Code CLI agent (-a claude_cli)
# Requires Claude Code installed (`claude` on PATH).
# Auth and models come from the vars below or `claude auth login`.
# =============================================================================

# Auth mode A — native Anthropic API:
# ANTHROPIC_API_KEY=sk-ant-...

# Auth mode B — Anthropic-compatible proxy (e.g. DeepSeek):
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_AUTH_TOKEN=sk-...

# Model defaults when -m is omitted (first non-empty wins):
#   ANTHROPIC_MODEL → CLAUDE_CODE_SUBAGENT_MODEL → ANTHROPIC_DEFAULT_SONNET_MODEL
# ANTHROPIC_MODEL=deepseek-v4-pro[1m]
# ANTHROPIC_DEFAULT_OPUS_MODEL=
# ANTHROPIC_DEFAULT_SONNET_MODEL=
# ANTHROPIC_DEFAULT_HAIKU_MODEL=
# CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash
# CLAUDE_CODE_EFFORT_LEVEL=max

# =============================================================================
# LLM judge (nika eval judge / nika benchmark run --judge)
# =============================================================================

NIKA_JUDGE_PROVIDER=openai
NIKA_JUDGE_MODEL=gpt-5-mini
