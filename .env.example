# Copy to .env and fill in values.
# Usage: README.md § Configure environment variables | src/agent/README.md
# CLI flags override .env when both are set.

# Optional parent directory for session outputs (nika env run / nika benchmark run).
# Default: results/ at repo root. Example: results/list1 → results/list1/{session_id}/
# NIKA_RESULT_DIR=results/list1

# =============================================================================
# Shared (all agents — nika agent run / nika benchmark run)
# =============================================================================

# byo.langgraph | byo.mcp_agent | byo.autogen | local_cli.codex_cli | local_cli.claude_cli | community.sade | sdk.claude_sdk | sdk.codex_sdk
NIKA_AGENT_TYPE=byo.langgraph

# Per-phase step limit (byo.langgraph, byo.mcp_agent, byo.autogen, community.sade, sdk.claude_sdk)
NIKA_MAX_STEPS=20

# Load shared agent skills for Claude Code / Codex agents (see docs/agent-skills.md)
# NIKA_ENABLE_SKILLS=true

# Optional override for the skill library root (default: src/agent/skills/)
# NIKA_SKILLS_DIR=

# Optional model override for any agent (-m takes precedence)
# NIKA_MODEL=

# =============================================================================
# byo/langgraph — byo.langgraph (-a byo.langgraph)
# =============================================================================

# openai | ollama | deepseek | custom
NIKA_LLM_PROVIDER=openai

NIKA_LANGGRAPH_MODEL=gpt-5-mini

# Provider credentials (set the one matching NIKA_LLM_PROVIDER)
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
OLLAMA_API_URL=http://localhost:11434

# Location of the custom provider, when NIKA_LLM_PROVIDER==custom
# CUSTOM_API_BASE=http://10.XXX.XXX.XXX:8010/v1

# =============================================================================
# byo/mcp_agent — byo.mcp_agent (-a byo.mcp_agent)
# =============================================================================

NIKA_MCP_AGENT_MODEL=gpt-4.1-mini
# Requires OPENAI_API_KEY (above).

# =============================================================================
# byo/autogen — byo.autogen (-a byo.autogen)
# =============================================================================

NIKA_AUTOGEN_MODEL=gpt-4.1-mini
# Requires OPENAI_API_KEY (above). When model id starts with deepseek, uses DEEPSEEK_API_KEY instead.

# =============================================================================
# local_cli/codex_cli — local_cli.codex_cli (-a local_cli.codex_cli)
# =============================================================================

# Requires Codex CLI on PATH (`codex`).
# Auth (pick one):
#   1 — Local login: `codex login` → ~/.codex/auth.json (no env vars)
#   2 — API key: OPENAI_API_KEY (see byo/langgraph block above)

NIKA_CODEX_MODEL=gpt-5.4-mini

# none | minimal | low | medium | high | xhigh
# NIKA_CODEX_REASONING_EFFORT=

# =============================================================================
# local_cli/claude_cli — local_cli.claude_cli (-a local_cli.claude_cli)
# =============================================================================

# Requires Claude Code on PATH (`claude`).
# Auth (pick one):
#   1 — Env API credentials (NIKA runs `claude --bare`):
#       • Native Anthropic: ANTHROPIC_API_KEY
#       • Compatible proxy (e.g. DeepSeek): ANTHROPIC_BASE_URL + ANTHROPIC_AUTH_TOKEN
#   2 — OAuth: `claude auth login` (no env vars below; CLI reads stored session)

# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_AUTH_TOKEN=sk-...

# Model when -m omitted (first non-empty wins):
#   ANTHROPIC_MODEL → CLAUDE_CODE_SUBAGENT_MODEL → ANTHROPIC_DEFAULT_SONNET_MODEL
# ANTHROPIC_MODEL=deepseek-v4-pro[1m]
# ANTHROPIC_DEFAULT_OPUS_MODEL=
# ANTHROPIC_DEFAULT_SONNET_MODEL=
# ANTHROPIC_DEFAULT_HAIKU_MODEL=
# CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash
# CLAUDE_CODE_EFFORT_LEVEL=max

# =============================================================================
# community/sade — community.sade (-a community.sade)
# =============================================================================

# Requires: uv sync --extra sade
# Auth: same as local_cli.claude_cli method 1 (env API only; OAuth not supported).
# Model: ANTHROPIC_MODEL chain above, or optional override:
# NIKA_SADE_MODEL=deepseek-v4-pro[1m]

# =============================================================================
# sdk/claude_sdk — sdk.claude_sdk (-a sdk.claude_sdk)
# =============================================================================

# Requires: uv sync --extra sdk --prerelease=allow
# Auth: same as local_cli.claude_cli method 1 (env API only; OAuth not supported):
#   • Native Anthropic: ANTHROPIC_API_KEY
#   • Compatible proxy (e.g. DeepSeek): ANTHROPIC_BASE_URL + ANTHROPIC_AUTH_TOKEN
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_AUTH_TOKEN=sk-...
# Model: ANTHROPIC_MODEL chain (local_cli/claude_cli block), or optional override:
# NIKA_CLAUDE_SDK_MODEL=deepseek-v4-pro[1m]

# =============================================================================
# sdk/codex_sdk — sdk.codex_sdk (-a sdk.codex_sdk)
# =============================================================================

# Requires: uv sync --extra sdk --prerelease=allow
# Auth: same as local_cli.codex_cli method 1 (local login only; OPENAI_API_KEY not supported):
#   `codex login` → ~/.codex/auth.json
# Model: NIKA_CODEX_MODEL (local_cli/codex_cli block), or optional override:
# NIKA_CODEX_SDK_MODEL=gpt-5.4-mini
# Reasoning effort: NIKA_CODEX_REASONING_EFFORT (local_cli/codex_cli block)

# =============================================================================
# Observability
# =============================================================================

# Langfuse — byo.langgraph
# https://langfuse.com/docs
# NIKA_LANGFUSE_ENABLED=true
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# =============================================================================
# LLM judge (nika eval judge / nika benchmark run --judge)
# =============================================================================

NIKA_JUDGE_PROVIDER=openai
NIKA_JUDGE_MODEL=gpt-5-mini

# =============================================================================
# Agent sandbox (nika agent run --sandbox)
# =============================================================================

# Run supported CLI/SDK agents inside Docker (see docs/agent-sandbox.md)
# NIKA_AGENT_SANDBOX=false

# NIKA_SANDBOX_IMAGE=nika/agent-sandbox:latest
# NIKA_SANDBOX_ENV_FILE=.env
# NIKA_SANDBOX_NETWORK=bridge
# Local-only sandbox overrides (optional): copy .env.sandbox.local.example → .env.sandbox.local
# Proxy settings belong there and are off by default; see docs/agent-sandbox.md
# NIKA_SANDBOX_KEEP=false
# NIKA_SANDBOX_CPUS=
# NIKA_SANDBOX_MEMORY=
# Optional read-only Codex auth mount when OPENAI_API_KEY is unset:
# NIKA_SANDBOX_CODEX_AUTH_FILE=~/.codex/auth.json
