NIKA_AGENT_TYPE=byo.langgraph
NIKA_MAX_STEPS=20

NIKA_MODEL=openai/gpt-oss-120b
NIKA_LLM_PROVIDER=custom

NIKA_LANGGRAPH_MODEL=openai/gpt-oss-120b

# Shared learning-module defaults. Studio role-specific model fields override these.
NIKA_LEARNING_LLM_BACKEND=custom
NIKA_LEARNING_LLM_MODEL=openai/gpt-oss-120b
NIKA_LEARNING_LLM_TIMEOUT_SECONDS=20
NIKA_LEARNING_LLM_MAX_RETRIES=0
NIKA_SKILL_LOGPROB_MODEL=openai/gpt-oss-120b

# Provider credentials (set the one matching NIKA_LLM_PROVIDER)
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
OLLAMA_API_URL=http://localhost:11434

# Location of the custom provider, when NIKA_LLM_PROVIDER==custom
CUSTOM_API_URL=https://stream-netmind.viettel.vn/gateway/v1
CUSTOM_API_BASE=https://stream-netmind.viettel.vn/gateway/v1
CUSTOM_API_KEY=
CUSTOM_TIMEOUT_SECONDS=90
CUSTOM_MAX_RETRIES=5

NIKA_MCP_AGENT_MODEL=gpt-4.1-mini
NIKA_AUTOGEN_MODEL=gpt-4.1-mini
NIKA_CODEX_MODEL=gpt-5.4-mini

LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

NIKA_JUDGE_PROVIDER=custom
NIKA_JUDGE_MODEL=openai/gpt-oss-120b
